# Copier vers mailcow.conf puis :
#   chmod 600 mailcow.conf && ln -sf mailcow.conf .env
# Remplacer CHANGEME_* par des chaînes aléatoires (A–Z a–z 0–9), longueur ~28 pour DB*, 16 pour SOGO.

MAILCOW_HOSTNAME=mail.example.com

MAILCOW_PASS_SCHEME=BLF-CRYPT

DBNAME=mailcow
DBUSER=mailcow
DBPASS=CHANGEME_DB_PASS_28_CHARS____
DBROOT=CHANGEME_DB_ROOT_28_CHARS___

REDISPASS=CHANGEME_REDIS_28_CHARS_____

HTTP_PORT=8080
HTTP_BIND=
HTTPS_PORT=8443
HTTPS_BIND=
HTTP_REDIRECT=y

SMTP_PORT=25
SMTPS_PORT=465
SUBMISSION_PORT=587
IMAP_PORT=143
IMAPS_PORT=993
POP_PORT=110
POPS_PORT=995
SIEVE_PORT=4190
DOVEADM_PORT=127.0.0.1:19991
SQL_PORT=127.0.0.1:13306
REDIS_PORT=127.0.0.1:7654

TZ=Europe/Paris

COMPOSE_PROJECT_NAME=mailcowdockerized
DOCKER_COMPOSE_VERSION=native

ACL_ANYONE=disallow
MAILDIR_GC_TIME=7200
ADDITIONAL_SAN=
AUTODISCOVER_SAN=y
ADDITIONAL_SERVER_NAMES=

SKIP_LETS_ENCRYPT=n
ACME_DNS_CHALLENGE=n
ACME_DNS_PROVIDER=dns_xxx
ACME_ACCOUNT_EMAIL=postmaster@example.com

ENABLE_SSL_SNI=n
SKIP_IP_CHECK=n
SKIP_HTTP_VERIFICATION=n
SKIP_UNBOUND_HEALTHCHECK=n
# y = moins de RAM/CPU (pas de scan antivirus des PJ). Rspamd (antispam) reste actif.
SKIP_CLAMD=y
SKIP_OLEFY=y
SKIP_SOGO=n
# y = désactive la recherche étendue dans les mails (Flatcurve).
SKIP_FTS=y
FTS_HEAP=128
FTS_PROCS=1
ALLOW_ADMIN_EMAIL_LOGIN=n
USE_WATCHDOG=y
WATCHDOG_NOTIFY_BAN=n
WATCHDOG_NOTIFY_START=y
WATCHDOG_EXTERNAL_CHECKS=n
WATCHDOG_VERBOSE=n
LOG_LINES=9999

# Éviter tout chevauchement avec `docker network inspect` sur le serveur (ex. pas 172.22.x si déjà utilisé)
IPV4_NETWORK=172.26.1
IPV6_NETWORK=fd4d:6169:6c63:6f77::/64

MAILDIR_SUB=Maildir
SOGO_EXPIRE_SESSION=480
SOGO_URL_ENCRYPTION_KEY=CHANGEME16CHARS0

DOVECOT_MASTER_USER=
DOVECOT_MASTER_PASS=

WEBAUTHN_ONLY_TRUSTED_VENDORS=n
SPAMHAUS_DQS_KEY=

ENABLE_IPV6=false
DISABLE_NETFILTER_ISOLATION_RULE=n
